<Window x:Class="slider_fontsize.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:slider_fontsize"
        mc:Ignorable="d"
        Title="MainWindow" Height="800" Width="450">
    <Grid>
        <Label FontWeight="Bold" Foreground="White" Width="450" Background="#558B2F" HorizontalAlignment="Left" FontSize="40" Content="Właściwości czcionki" Margin="0,43,0,0" VerticalAlignment="Top"/>
        <Label x:Name="SizeText" FontSize="20" Padding="0, 0, 0, 0" Content="Rozmiar: " HorizontalAlignment="Left" Margin="25,169,0,0" VerticalAlignment="Top"/>
        <Slider x:Name="MySlider" Maximum="40" Minimum="1" Width="400" HorizontalAlignment="center" Margin="0,210,0,0" VerticalAlignment="Top" SmallChange="1" />
        <Label x:Name="OutputText" Padding="0, 0, 0, 0" Content="..." HorizontalAlignment="Left" Margin="34,262,0,0" VerticalAlignment="Top"/>
        <Button x:Name="MyButton" Click="NextText_Click" FontWeight="Bold" Foreground="White" Background="#558B2F" Content=">>" HorizontalAlignment="Center"  VerticalAlignment="Top" Margin="0,336,0,0" Height="40" Width="138"/>
    </Grid>
</Window>
